# Start from the existing PyTorch ROCm image (same as working Dockerfile)
FROM ubuntu:22.04
#FROM rocm/pytorch-private:20251030_rocm_e2e_phantom_mi350_genai_nightly

# Switch to root to install packages
USER root

# Basic system setup
RUN apt-get update && apt-get install -y \
    wget \
    gnupg2 \
    software-properties-common \
    apt-utils \
    ca-certificates \
    curl \
    git \
    vim \
    build-essential \
    pkg-config \
    python3.10 \
    python3.10-dev \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Download and install amdgpu-install package for debian
RUN wget https://artifactory-cdn.amd.com:8443/artifactory/list/amdgpu-deb/amdgpu-install-internal_7.0.2.1-22.04-1_all.deb
RUN apt-get update && \
    apt-get install -y ca-certificates gnupg lsb-release sudo && \
    apt-get install -y ./amdgpu-install-internal_7.0.2.1-22.04-1_all.deb

## Configure amdgpu-repo with specific builds (ROCm 7.0.2.1 Build #17)

# Point repos at Build #17 (amdgpu-build=2299626, rocm-build=compute-rocm-rel-7.0.2.1/17)
RUN amdgpu-repo --amdgpu-build=2299626 --rocm-build=compute-rocm-rel-7.0.2.1/17


RUN apt-get update && apt-get install -y \
    rocm-hip-sdk \
    rocm-libs \
    rocblas \
    hipblaslt \
    rocm-dev \
    && rm -rf /var/lib/apt/lists/*

ENV ROCM_HOME=/opt/rocm
ENV PATH=$ROCM_HOME/bin:$PATH
ENV LD_LIBRARY_PATH=$ROCM_HOME/lib:$LD_LIBRARY_PATH

# Upgrade pip and install basic Python packages
RUN python3 -m pip install --upgrade pip setuptools wheel

# PyTorch Build Configuration Flags
# ==================================

# _GLIBCXX_USE_CXX11_ABI=1
# Enable C++11 ABI for GCC/libstdc++. This ensures compatibility with pre-built
# binaries and libraries that use the new C++11 ABI (default since GCC 5.1).
# Set to 0 for old ABI compatibility with legacy libraries.
ENV _GLIBCXX_USE_CXX11_ABI=1

# USE_ROCM_CK_SDPA=0
# Disable ROCm Composable Kernel (CK) backend for Scaled Dot Product Attention (SDPA).
# When set to 0, PyTorch will use generic/fallback implementations for attention layers
# instead of CK-optimized kernels. This may be needed for:
# - Debugging: Isolate issues related to CK kernels
# - Compatibility: Some CK kernels may not support all input shapes/dtypes
# - Stability: Use more mature fallback implementations
# Set to 1 to enable CK optimized attention kernels for better transformer performance.
ENV USE_ROCM_CK_SDPA=1

# PYTORCH_ROCM_ARCH=gfx950
# Specify target GPU architecture for ROCm compilation. This tells PyTorch to
# generate optimized code for specific AMD GPU architecture(s).
# - gfx950: AMD MI350 series GPUs
# Multiple architectures can be specified with semicolons: gfx90a;gfx940;gfx950
# Matching the exact architecture improves performance but increases build time.
ENV PYTORCH_ROCM_ARCH=gfx950

# USE_ROCM=1
# Enable building and using the ROCm backend in PyTorch. This must be set for
# HIP/ROCm builds so that PyTorch compiles ROCm-specific kernels and links
# against ROCm libraries instead of CUDA or CPU-only backends.
ENV USE_ROCM=1

# USE_FLASH_ATTENTION=1
# Enable flash-attention style fused attention kernels in PyTorch. These provide
# high-performance scaled dot-product attention for transformer models when
# supported by the backend (here, ROCm) and are recommended for training speed.
ENV USE_FLASH_ATTENTION=1

# USE_MEM_EFF_ATTENTION=1
# Enable memory-efficient attention kernels in PyTorch. These implementations
# reduce peak memory usage for large sequence lengths and are complementary to
# flash attention; enabling both allows PyTorch to pick the best kernel per case.
ENV USE_MEM_EFF_ATTENTION=1

# DISABLE_AOTRITON=1
# Disable Ahead-Of-Time (AOT) compiled Triton kernels. On some ROCm stacks,
# AOT Triton is not yet fully compatible or may cause build/runtime issues, so
# we turn it off to force use of non-AOT or alternative kernels instead.
ENV DISABLE_AOTRITON=1

# CK_TILE_FMHA_FWD_FAST_EXP2=1
# Enable Composable Kernel tiled fused multi-head attention (FMHA) forward path
# that uses a fast exp2-based approximation. This improves FMHA performance on
# supported ROCm GPUs at the cost of a small loss in numerical precision.
ENV CK_TILE_FMHA_FWD_FAST_EXP2=1

# FLASH_NAMESPACE=pytorch_flash
# Select the C++ namespace used for flash-attention kernels. This must match
# the namespace expected by the PyTorch build to avoid symbol clashes and to
# ensure the correct flash-attention implementation is linked.
ENV FLASH_NAMESPACE=pytorch_flash

# =============================================================================
# Client runtime environment flags
# =============================================================================
ENV NCCL_MAX_NCHANNELS=48
ENV HSA_KERNARG_POOL_SIZE=4194304
ENV HSA_NO_SCRATCH_RECLAIM=1
ENV AMDGCN_USE_BUFFER_OPS=1
ENV TORCHINDUCTOR_MAX_AUTOTUNE_POINTWISE=1
ENV FBGEMM_NO_JK=1
ENV FBGEMM_TBE_V2=1
ENV FBGEMM_TBE_ROCM_HIP_BACKWARD_KERNEL=1
ENV FBGEMM_BOUNDS_CHECK_INDICES_V2=1
ENV PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Clone PyTorch source repository
RUN git clone https://github.com/pytorch/pytorch.git -b v2.11.0-rc2

# Build PyTorch for AMD/ROCm
# The build_amd.py script applies ROCm-specific patches and prepares the source
# for compilation with AMD GPU support. This includes:
# - Applying ROCm compatibility patches
# - Setting up ROCm-specific build configurations
# - Preparing HIPified CUDA kernels (CUDA -> HIP translation)
RUN cd pytorch && \
    git submodule update --init --recursive && \
    python3.10 tools/amd_build/build_amd.py

# Install modern CMake (required by PyTorch)
RUN wget -qO - https://apt.kitware.com/keys/kitware-archive-latest.asc | gpg --dearmor -o /usr/share/keyrings/kitware.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/kitware.gpg] https://apt.kitware.com/ubuntu/ jammy main" \
      > /etc/apt/sources.list.d/kitware.list && \
    apt-get update && \
    apt-get install -y cmake && \
    cmake --version

# Install PyTorch build dependencies
RUN pip3 install --no-cache-dir \
	pyyaml \
	typing_extensions \
    numpy \
    pandas

# Build and install PyTorch from source in development mode
# =========================================================
# Using 'setup.py develop' instead of 'setup.py install' creates a development
# installation where the source directory is linked rather than copied. This allows:
# - Faster rebuilds during development (changes reflected immediately)
# - Easier debugging (source code available)
# - Lower disk space usage
#
# Build flags inherited from environment variables:
# - USE_ROCM=1 (auto-detected from ROCM_HOME)
# - PYTORCH_ROCM_ARCH=gfx950 (target GPU architecture)
# - USE_ROCM_CK_SDPA=0 (disable CK optimized attention kernels, use fallback)
# - _GLIBCXX_USE_CXX11_ABI=1 (C++11 ABI compatibility)
#
# Additional implicit build flags (can be overridden):
# - USE_CUDA=0 (disabled, using ROCm instead)
# - BUILD_TEST=0 (skip building C++ tests, set to 1 to enable)
# - USE_DISTRIBUTED=1 (enable distributed training support)
# - USE_NCCL=1 (enable RCCL for AMD GPUs, equivalent to NCCL for NVIDIA)
#
# NOTE: Building PyTorch from source is a resource-intensive and time-consuming step.
# - Expected build time: 1–2+ hours depending on CPU and network speed.
# - Recommended resources: at least 8 GB RAM (16 GB+ preferred) and multiple CPU cores.
# - When building inside Docker Desktop or similar environments, ensure the Docker daemon
#   has sufficient memory and CPU allocated (e.g., increase the memory limit) or the build
#   may fail with out-of-memory errors or take an excessively long time.
# - If builds repeatedly fail due to resource constraints, consider using prebuilt PyTorch
#   ROCm images or wheels instead of building from source.
RUN cd pytorch && python3.10 setup.py develop


# Install PyTorch 2.11.0 with ROCm 7.0 support
# Note: PyTorch 2.11 nightly builds for ROCm 7.0
#RUN pip3 install --pre \
#    torch==2.11.0.dev20260202+rocm7.0 \
#    torchvision==0.25.0.dev20260203+rocm7.0 \
#    torchaudio==2.11.0.dev20260203+rocm7.0 \
#    --index-url https://download.pytorch.org/whl/nightly/rocm7.0

# Verify installations
RUN python3.10 -c "import torch; print(f'PyTorch version: {torch.__version__}')" && \
    python3.10 -c "import torch; print(f'ROCm available: {torch.cuda.is_available()}')" && \
    python3.10 -c "import torch; print(f'GPU count: {torch.cuda.device_count()}')"

# Set up work directory
WORKDIR /workspace/sdpa

CMD ["/bin/bash"]
