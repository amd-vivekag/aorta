# Start from the existing PyTorch ROCm image
FROM rocm/pytorch-private:20251030_rocm_e2e_phantom_mi350_genai_nightly

# Switch to root to install packages
USER root

# Install wget if not available (try both yum and apt-get)
RUN yum install -y wget 2>/dev/null || apt-get update && apt-get install -y wget || true

# Download and install amdgpu-install package for RHEL
RUN wget https://artifactory-cdn.amd.com/artifactory/list/amdgpu-rpm/rhel/amdgpu-install-internal-7.0_9-1.noarch.rpm && \
    yum install -y ./amdgpu-install-internal-7.0_9-1.noarch.rpm || rpm -ivh ./amdgpu-install-internal-7.0_9-1.noarch.rpm && \
    rm amdgpu-install-internal-7.0_9-1.noarch.rpm

# Update amdgpu-repo with specific builds (ROCm 7.0 Build #19, Jan 20, 2026)
RUN amdgpu-repo --amdgpu-build=2281818 --rocm-build=compute-rocm-rel-7.0-meta/19

# Since base image already has ROCm, just update the key runtime components
# instead of doing a full reinstall which causes dependency conflicts
RUN yum update -y --skip-broken \
    rocm-hip \
    rocm-libs \
    rocm-hip-libraries \
    rocm-hip-runtime-devel \
    hip-base \
    hip-dev \
    hip-runtime-amd \
    rocm-core || echo "Updated available ROCm packages"


# Install TraceLens and additional Python packages
# TODO : Add a pinned commit check to avoid malicious download
RUN python3.10 -m pip install git+https://github.com/AMD-AGI/TraceLens.git || echo "TraceLens install failed, continuing..."
RUN python3.10 -m pip install openpyxl seaborn pandas matplotlib pyyaml tqdm tensorboard

# Download and install rocprof-trace-decoder to enable `--att` flag in rocprofv3
# TODO : Add a pinned checksum check to avoid malicious download.
RUN wget https://github.com/ROCm/rocprof-trace-decoder/releases/download/0.1.6/rocprof-trace-decoder-manylinux-2.28-0.1.6-Linux.rpm \
    -O /tmp/rocprof-trace-decoder.rpm && \
    rpm -i /tmp/rocprof-trace-decoder.rpm || echo "rocprof-trace-decoder install failed, continuing..." && \
    rm -f /tmp/rocprof-trace-decoder.rpm

# Install Facebook Distributed Shampoo optimizer
# TODO : Add some pinned commit or checksum check for malicious download.
RUN cd /tmp && \
    git clone https://github.com/facebookresearch/optimizers.git && \
    cd optimizers && \
    sed -i 's/requires-python = ">=.*"/requires-python = ">=3.10"/' pyproject.toml && \
    python3.10 -m pip install . || echo "Shampoo install failed, continuing..." && \
    cd / && \
    rm -rf /tmp/optimizers

# Update environment variables to ensure new ROCm is used
ENV ROCM_HOME=/opt/rocm
ENV PATH=$ROCM_HOME/bin:$PATH
ENV LD_LIBRARY_PATH=$ROCM_HOME/lib:$LD_LIBRARY_PATH

# Verify installations
RUN python3.10 -c "import torch; print(f'PyTorch version: {torch.__version__}')" && \
    python3.10 -c "import torch; print(f'ROCm available: {torch.cuda.is_available()}')" && \
    python3.10 -c "import torch; print(f'GPU count: {torch.cuda.device_count()}')"

RUN python3.10 -c "import distributed_shampoo; print('[OK] Shampoo optimizer installed successfully')" || \
    echo "[WARN] Shampoo optimizer not available"

# Set working directory
WORKDIR /workspace/aorta

CMD ["/bin/bash"]
