# =============================================================================
# TheRock HOST_ASAN HIP Runtime + PyTorch
# =============================================================================
#
# Builds ROCm/HIP from source via TheRock with host-only AddressSanitizer
# (HOST_ASAN), then builds PyTorch against that instrumented stack.
#
# HOST_ASAN instruments host-side C/C++ code with -fsanitize=address but does
# NOT modify GPU_TARGETS for xnack+ device-side ASAN.  The linux-release-host-asan
# preset applies HOST_ASAN globally to all compiled code; the compiler (amd-llvm)
# and a few tooling components are excluded per the upstream preset defaults.
# This is useful for catching host memory errors (e.g. in hipEventQuery) on any
# GPU hardware without requiring xnack-capable devices (gfx942/gfx950).
#
# References:
#   - TheRock sanitizer docs : https://github.com/ROCm/TheRock/blob/main/docs/development/sanitizers.md
#   - HOST_ASAN preset PR    : https://github.com/ROCm/TheRock/pull/3137
#   - CMakePresets.json       : https://github.com/ROCm/TheRock/blob/main/CMakePresets.json
#
# Build:
#   docker build \
#     --build-arg THEROCK_AMDGPU_FAMILIES=gfx94X-dcgpu \
#     --build-arg PYTORCH_ROCM_ARCH=gfx950 \
#     -f docker/Dockerfile.therock-host-asan-pytorch \
#     -t therock-host-asan-pytorch .
#
# Run (GPU passthrough):
#   docker run -it --rm \
#     --device=/dev/kfd --device=/dev/dri \
#     --ipc=host --group-add=video --group-add=render \
#     -e ASAN_OPTIONS="detect_leaks=1:halt_on_error=0:symbolize=1:log_path=/workspace/asan.log" \
#     therock-host-asan-pytorch
#
# ASAN runtime options (set via ASAN_OPTIONS env var):
#   detect_leaks=1    - enable leak detection (default off for mixed Python)
#   halt_on_error=0   - continue execution after the first error
#   log_path=asan.log - write reports to file instead of stderr
#   symbolize=1       - show function names in stack traces
#
# Sanitizer + Python caveat:
#   ASAN expects a single instrumented process.  A non-ASAN Python interpreter
#   loading ASAN-instrumented libamdhip64.so can produce false positives or miss
#   errors.  For focused hipEventQuery testing, prefer small C++/HIP repros
#   compiled with TheRock's toolchain under ASAN.  A future follow-up image
#   using ROCm's pytorch rocm-asan branch (.ci/pytorch/build-rocm-asan.sh) will
#   provide full host+device ASAN coverage for PyTorch itself.
#
# =============================================================================

FROM ubuntu:24.04

USER root

# ---------------------------------------------------------------------------
# Build arguments
# ---------------------------------------------------------------------------

# TheRock source ref (branch, tag, or commit SHA)
ARG THEROCK_GIT_REF=main

# Required: AMD GPU family for TheRock (e.g. gfx94X-dcgpu, gfx110X-all)
ARG THEROCK_AMDGPU_FAMILIES=gfx950

# PyTorch source ref (stable release tag)
ARG PYTORCH_GIT_REF=v2.11.0-rc2

# PyTorch GPU arch — should match THEROCK_AMDGPU_FAMILIES
ARG PYTORCH_ROCM_ARCH=gfx950

# TheRock install prefix (becomes ROCM_HOME)
ARG ROCM_INSTALL_PREFIX=/opt/rocm

# ON (default): ROCm subset needed to configure PyTorch against TheRock
# (math + ML + PRIM + comm + compiler + HIP). Skips DC tools (RDC) which
# break under HOST_ASAN (gRPC protoc / libclang_rt.asan).
# OFF: default TheRock feature set (still with DC tools disabled below).
ARG THEROCK_MINIMAL=ON

# ---------------------------------------------------------------------------
# Stage 1: System packages (TheRock + PyTorch build deps)
# ---------------------------------------------------------------------------

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    gfortran \
    git \
    ninja-build \
    cmake \
    g++ \
    pkg-config \
    xxd \
    patchelf \
    automake \
    libtool \
    python3-venv \
    python3-dev \
    python3-pip \
    libegl1-mesa-dev \
    liblzma-dev \
    texinfo \
    bison \
    flex \
    wget \
    curl \
    ca-certificates \
    gnupg2 \
    vim \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Stage 2: Build TheRock with HOST_ASAN preset
# ---------------------------------------------------------------------------

WORKDIR /build

RUN git clone --branch ${THEROCK_GIT_REF} --single-branch \
    https://github.com/ROCm/TheRock.git

WORKDIR /build/TheRock

# Python venv for TheRock build tooling
RUN python3 -m venv .venv && \
    . .venv/bin/activate && \
    pip install --upgrade pip && \
    pip install -r requirements.txt && \
    python3 ./build_tools/fetch_sources.py

# Configure with the linux-release-host-asan preset.
# The preset sets THEROCK_SANITIZER=HOST_ASAN globally and adds
# -fsanitize=address to CMAKE_C/CXX_FLAGS for ALL compiled code.
# Per-component _SANITIZER=OFF only works for TheRock's own sub-projects;
# third-party deps (yaml-cpp, etc.) always inherit the global ASAN flags.
# Selectively disabling ASAN on individual components causes link mismatches
# (ASAN-instrumented static libs linked into non-ASAN executables).
# Therefore we use the preset as designed with only the overrides from the
# upstream CMakePresets.json (amd-llvm, hipcc, hipify, etc. OFF).
#
# PyTorch LoadHIP.cmake (e.g. v2.7) requires: rocrand, hiprand, rocblas, hipblas,
# miopen, hipfft, hipsparse, rocprim, hipcub, rocthrust, hipsolver, hiprtc,
# hipblaslt — satisfied by MATH + ML + PRIM + COMM groups with compiler + HIP.
RUN . .venv/bin/activate && \
    MINIMAL_FLAGS="" && \
    if [ "${THEROCK_MINIMAL}" = "ON" ]; then \
        MINIMAL_FLAGS="-DTHEROCK_ENABLE_ALL=OFF \
                       -DTHEROCK_ENABLE_CORE_RUNTIME=ON \
                       -DTHEROCK_ENABLE_HIP_RUNTIME=ON \
                       -DTHEROCK_ENABLE_COMPILER=ON \
                       -DTHEROCK_ENABLE_MATH_LIBS=ON \
                       -DTHEROCK_ENABLE_ML_LIBS=ON \
                       -DTHEROCK_ENABLE_PRIM=ON \
                       -DTHEROCK_ENABLE_COMM_LIBS=ON"; \
    fi && \
    cmake --preset linux-release-host-asan \
        -B build \
        -DTHEROCK_AMDGPU_FAMILIES=${THEROCK_AMDGPU_FAMILIES} \
        -DTHEROCK_ENABLE_DC_TOOLS=OFF \
        -DBUILD_TESTING=OFF \
        -Dtherock-SuiteSparse_SANITIZER=OFF \
        -Damdsmi_SANITIZER=OFF \
        ${MINIMAL_FLAGS}

RUN . .venv/bin/activate && \
    cmake --build build --target all

RUN cmake --install build --prefix ${ROCM_INSTALL_PREFIX}

# TheRock's RCCL install omits nccl_device.h (a device-level header required
# by PyTorch v2.11's NCCLSymmetricMemory). Copy it from the RCCL source tree.
RUN find /build/TheRock -name "nccl_device.h" -type f | head -1 | \
    xargs -I{} cp {} ${ROCM_INSTALL_PREFIX}/include/ && \
    ls -la ${ROCM_INSTALL_PREFIX}/include/nccl_device.h

# ---------------------------------------------------------------------------
# Stage 3: ROCm environment
# ---------------------------------------------------------------------------

ENV ROCM_HOME=${ROCM_INSTALL_PREFIX}
ENV ROCM_PATH=${ROCM_INSTALL_PREFIX}
ENV HIP_PATH=${ROCM_INSTALL_PREFIX}
ENV CMAKE_PREFIX_PATH=${ROCM_INSTALL_PREFIX}
ENV PATH=${ROCM_HOME}/bin:${PATH}
ENV LD_LIBRARY_PATH=${ROCM_HOME}/lib:${LD_LIBRARY_PATH}

# ---------------------------------------------------------------------------
# Stage 4: Build PyTorch from source against the ASAN ROCm stack
# ---------------------------------------------------------------------------

# PyTorch build configuration
ENV _GLIBCXX_USE_CXX11_ABI=1
ENV PYTORCH_ROCM_ARCH=${PYTORCH_ROCM_ARCH}
ENV USE_ROCM=1
ENV USE_ROCM_CK_SDPA=1
ENV USE_FLASH_ATTENTION=1
ENV USE_MEM_EFF_ATTENTION=1
ENV DISABLE_AOTRITON=1
ENV CK_TILE_FMHA_FWD_FAST_EXP2=1
ENV FLASH_NAMESPACE=pytorch_flash

# Limit parallel compilation jobs — ASAN-instrumented compiler uses ~2-3x more
# memory per process, so unrestricted parallelism OOM-kills subcommands.
ENV MAX_JOBS=16

# Runtime tuning
ENV NCCL_MAX_NCHANNELS=48
ENV HSA_KERNARG_POOL_SIZE=4194304
ENV HSA_NO_SCRATCH_RECLAIM=1
ENV AMDGCN_USE_BUFFER_OPS=1
ENV TORCHINDUCTOR_MAX_AUTOTUNE_POINTWISE=1
ENV FBGEMM_NO_JK=1
ENV FBGEMM_TBE_V2=1
ENV FBGEMM_TBE_ROCM_HIP_BACKWARD_KERNEL=1
ENV FBGEMM_BOUNDS_CHECK_INDICES_V2=1
ENV PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Install modern CMake (required by PyTorch)
RUN wget -qO - https://apt.kitware.com/keys/kitware-archive-latest.asc | gpg --dearmor -o /usr/share/keyrings/kitware.gpg && \
    echo "deb [signed-by=/usr/share/keyrings/kitware.gpg] https://apt.kitware.com/ubuntu/ noble main" \
      > /etc/apt/sources.list.d/kitware.list && \
    apt-get update && \
    apt-get install -y cmake && \
    cmake --version

RUN python3 -m venv /opt/pytorch-venv && \
    /opt/pytorch-venv/bin/pip install --upgrade pip setuptools wheel && \
    /opt/pytorch-venv/bin/pip install --no-cache-dir \
    pyyaml \
    typing_extensions \
    numpy \
    pandas

ENV PATH=/opt/pytorch-venv/bin:${PATH}

WORKDIR /build

RUN git clone --branch ${PYTORCH_GIT_REF} --single-branch \
    https://github.com/pytorch/pytorch.git

RUN cd pytorch && \
    git submodule update --init --recursive && \
    python3 tools/amd_build/build_amd.py

# Use the RCCL installed by TheRock instead of PyTorch's bundled NCCL.
# TheRock installs RCCL headers/libs to /opt/rocm; without this, PyTorch
# can't find nccl_device.h needed by NCCLSymmetricMemory.
ENV USE_SYSTEM_NCCL=1
ENV NCCL_ROOT=/opt/rocm
ENV NCCL_INCLUDE_DIR=/opt/rocm/include
ENV NCCL_LIB_DIR=/opt/rocm/lib

RUN cd pytorch && python3 setup.py develop

# Verify installations
RUN python3 -c "import torch; print(f'PyTorch version: {torch.__version__}')" && \
    python3 -c "import torch; print(f'ROCm available: {torch.cuda.is_available()}')" && \
    python3 -c "import torch; print(f'GPU count: {torch.cuda.device_count()}')"

# ---------------------------------------------------------------------------
# Default ASAN_OPTIONS — sensible defaults for interactive debugging.
# Override at runtime: docker run -e ASAN_OPTIONS="..." ...
# ---------------------------------------------------------------------------
ENV ASAN_OPTIONS="detect_leaks=0:halt_on_error=0:symbolize=1"

WORKDIR /workspace
CMD ["/bin/bash"]
