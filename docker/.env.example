# Docker Compose Environment Configuration
# Copy this file to .env and customize for your setup
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your settings
#   docker compose -f docker-compose.build.yaml up

# ==============================================================================
# DOCKERFILE SELECTION (Required)
# ==============================================================================
# Choose which Dockerfile to build from. Available options:
#
# - Dockerfile.rocm70_9-1              Standard ROCm 7.0.9.1 build
# - Dockerfile.rocm70_9-1-shampoo      ROCm 7.0.9.1 with Shampoo optimizer
# - Dockerfile.rocm70_2-ubuntu-pytorch ROCm 7.0.2 Ubuntu PyTorch build
# - Dockerfile.rocm70_2-ubuntu-nan     ROCm 7.0.2 with NaN debugging tools
#
DOCKERFILE=Dockerfile.rocm70_9-1

# ==============================================================================
# CONTAINER NAME (Required)
# ==============================================================================
# Set a unique name for your container to avoid conflicts with other users
# Recommended format: ${USER}-${variant}-${experiment}
#
# Examples:
#   CONTAINER_NAME=username-rocm70-baseline
#   CONTAINER_NAME=training-overlap-debug-20260205
#   CONTAINER_NAME=shampoo-optimizer-test
#
CONTAINER_NAME=training-overlap-bugs-default

# ==============================================================================
# VOLUME MOUNTS
# ==============================================================================

# Path to the aorta workspace directory
# Default: .. (parent directory, assumes you're running from docker/ subdirectory)
#
# Examples:
#   AORTA_WORKSPACE=..                              (relative path)
#   AORTA_WORKSPACE=/apps/<username>/aorta          (absolute path)
#
AORTA_WORKSPACE=..

# Path to RCCL build directory
# Default: /tmp/rccl_placeholder (dummy path if not using custom RCCL)
#
# Examples:
#   RCCL_PATH=/tmp/rccl_placeholder     (default - no custom RCCL)
#   RCCL_PATH=/home/username/rccl       (custom path)
#
RCCL_PATH=/tmp/rccl_placeholder

# Optional: Additional volume mounts (uncomment and customize if needed)
# These can be used for user-specific directories, shared data, etc.
#
# EXTRA_MOUNT_SRC_1=/home/manrao
# EXTRA_MOUNT_DST_1=/manrao
#
# EXTRA_MOUNT_SRC_2=/apps/oyazdanb/data
# EXTRA_MOUNT_DST_2=/data

# ==============================================================================
# ENVIRONMENT VARIABLES
# ==============================================================================

# AMD GPU driver variant for environment_info.json
# Possible values: "patched", "base", "mqd_vram", "default", or leave empty
# Default: empty (not set)
#
AMDGPU_DRIVER_VARIANT=

# ==============================================================================
# NOTES
# ==============================================================================
#
# 1. This .env file is git-ignored, so your personal configuration won't be
#    committed to the repository.
#
# 2. You can override any environment variable at runtime:
#    CONTAINER_NAME=my-test docker compose -f docker-compose.build.yaml up
#
# 3. To see which environment variables are being used:
#    docker compose -f docker-compose.build.yaml config
#
# 4. For quick setup, use the interactive script:
#    bash setup-env.sh
