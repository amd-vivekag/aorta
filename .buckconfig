[cells]
  root = .
  prelude = prelude
  toolchains = toolchains

[cell_aliases]
  config = prelude
  ovr_config = prelude
  fbcode = root
  fbsource = root
  fbcode_macros = root
  buck = root

[external_cells]
  prelude = bundled

[parser]
  target_platform_detector_spec = target:root//...->prelude//platforms:default \
    target:prelude//...->prelude//platforms:default \
    target:toolchains//...->prelude//platforms:default

[build]
  execution_platforms = prelude//platforms:default

# Short names for the targets users invoke most often. Lets a demo /
# walkthrough say `buck2 run aorta -- env probe --summary` instead of
# `buck2 run //:aorta -- env probe --summary`. Aliases are command-line
# sugar only -- the canonical labels in BUCK files don't change, so
# `cquery 'deps(//:aorta)'` and the equivalent `cquery 'deps(aorta)'`
# return the same graph.
[alias]
  aorta = //:aorta
  aorta_lib = //:aorta_lib
